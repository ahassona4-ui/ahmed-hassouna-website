{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ahmed-hassouna.example.invalid/schemas/content-model-v2.json",
  "title": "AH Website Unified Content Model v2.0 — Corrected Engineering Candidate #003",
  "description": "Canonical Option B+ contract with typed lifecycle states, conditional review metadata and governed structured claims.",
  "oneOf": [
    {
      "$ref": "#/$defs/project"
    },
    {
      "$ref": "#/$defs/article"
    }
  ],
  "$defs": {
    "localizedText": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ar",
        "en"
      ],
      "properties": {
        "ar": {
          "type": "string",
          "minLength": 1
        },
        "en": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "mediaAsset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "src",
        "decorative"
      ],
      "properties": {
        "src": {
          "type": "string",
          "pattern": "^/assets/[a-zA-Z0-9/_-]+\\.(?:webp|jpg|jpeg|png|svg)$"
        },
        "decorative": {
          "type": "boolean"
        },
        "alt": {
          "$ref": "#/$defs/localizedText"
        },
        "caption": {
          "$ref": "#/$defs/localizedText"
        },
        "credit": {
          "type": "string",
          "minLength": 1
        },
        "order": {
          "type": "integer",
          "minimum": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "decorative": {
                "const": false
              }
            },
            "required": [
              "decorative"
            ]
          },
          "then": {
            "required": [
              "alt"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "decorative": {
                "const": true
              }
            },
            "required": [
              "decorative"
            ]
          },
          "then": {
            "not": {
              "required": [
                "alt"
              ]
            }
          }
        }
      ]
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claim_id",
        "claim_type",
        "text",
        "approval_state"
      ],
      "properties": {
        "claim_id": {
          "type": "string",
          "pattern": "^[A-Z0-9-]+$"
        },
        "claim_type": {
          "type": "string",
          "enum": [
            "qualitative",
            "quantitative",
            "status",
            "credential",
            "scope"
          ]
        },
        "text": {
          "$ref": "#/$defs/localizedText"
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "boundary": {
          "$ref": "#/$defs/localizedText"
        },
        "approval_state": {
          "type": "string",
          "enum": [
            "pending",
            "verified",
            "baseline_approved",
            "approved",
            "rejected"
          ]
        },
        "approved_by": {
          "type": "string",
          "minLength": 1
        },
        "approved_at": {
          "$ref": "#/$defs/timezoneDateTime"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "claim_type": {
                "enum": [
                  "quantitative",
                  "status"
                ]
              }
            },
            "required": [
              "claim_type"
            ]
          },
          "then": {
            "required": [
              "evidence_refs",
              "boundary"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "claim_type": {
                "const": "credential"
              }
            },
            "required": [
              "claim_type"
            ]
          },
          "then": {
            "required": [
              "evidence_refs"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "approval_state": {
                "const": "approved"
              }
            },
            "required": [
              "approval_state"
            ]
          },
          "then": {
            "required": [
              "approved_by",
              "approved_at"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "approval_state": {
                "const": "baseline_approved"
              }
            },
            "required": [
              "approval_state"
            ]
          },
          "then": {
            "required": [
              "approved_by"
            ],
            "not": {
              "required": [
                "approved_at"
              ]
            }
          }
        }
      ]
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "content_review_state",
        "claim_review_state",
        "timestamp_state"
      ],
      "properties": {
        "content_review_state": {
          "type": "string",
          "enum": [
            "pending",
            "approved",
            "rejected"
          ]
        },
        "claim_review_state": {
          "type": "string",
          "enum": [
            "pending",
            "approved",
            "rejected"
          ]
        },
        "reviewed_by": {
          "type": "string",
          "minLength": 1
        },
        "timestamp_state": {
          "type": "string",
          "enum": [
            "not_recorded",
            "legacy_unrecorded",
            "recorded"
          ]
        },
        "reviewed_at": {
          "$ref": "#/$defs/timezoneDateTime"
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "timestamp_state": {
                "const": "recorded"
              }
            },
            "required": [
              "timestamp_state"
            ]
          },
          "then": {
            "required": [
              "reviewed_by",
              "reviewed_at"
            ],
            "properties": {
              "content_review_state": {
                "enum": [
                  "approved",
                  "rejected"
                ]
              },
              "claim_review_state": {
                "enum": [
                  "approved",
                  "rejected"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "timestamp_state": {
                "const": "legacy_unrecorded"
              }
            },
            "required": [
              "timestamp_state"
            ]
          },
          "then": {
            "required": [
              "reviewed_by"
            ],
            "properties": {
              "content_review_state": {
                "const": "approved"
              },
              "claim_review_state": {
                "const": "approved"
              }
            },
            "not": {
              "required": [
                "reviewed_at"
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "timestamp_state": {
                "const": "not_recorded"
              }
            },
            "required": [
              "timestamp_state"
            ]
          },
          "then": {
            "properties": {
              "content_review_state": {
                "const": "pending"
              },
              "claim_review_state": {
                "const": "pending"
              }
            },
            "not": {
              "required": [
                "reviewed_at"
              ]
            }
          }
        }
      ]
    },
    "seo": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "description",
        "canonical_path"
      ],
      "properties": {
        "title": {
          "$ref": "#/$defs/localizedText"
        },
        "description": {
          "$ref": "#/$defs/localizedText"
        },
        "canonical_path": {
          "type": "string",
          "pattern": "^/(?:projects|articles)/[a-z0-9]+(?:-[a-z0-9]+)*\\.html$"
        },
        "og_image": {
          "type": "string",
          "pattern": "^/assets/(?:uploads/(?:projects|articles)|articles)/[a-zA-Z0-9/_-]+\\.(?:webp|jpg|jpeg|png)$"
        }
      }
    },
    "articleSection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "section_id",
        "order",
        "heading",
        "body"
      ],
      "properties": {
        "section_id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "order": {
          "type": "integer",
          "minimum": 1
        },
        "heading": {
          "$ref": "#/$defs/localizedText"
        },
        "body": {
          "$ref": "#/$defs/localizedText"
        }
      }
    },
    "navigationTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "project_id"
      ],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^/projects/[a-z0-9]+(?:-[a-z0-9]+)*\\.html$"
        },
        "project_id": {
          "type": "string",
          "pattern": "^AH-PRJ-[0-9]{3}$"
        }
      }
    },
    "navigation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "previous",
        "back",
        "next"
      ],
      "properties": {
        "previous": {
          "$ref": "#/$defs/navigationTarget"
        },
        "next": {
          "$ref": "#/$defs/navigationTarget"
        },
        "back": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "path",
            "fragment"
          ],
          "properties": {
            "path": {
              "const": "/index.html"
            },
            "fragment": {
              "const": "work"
            }
          }
        }
      }
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "layout",
        "permalink",
        "body_class",
        "nav_active",
        "robots",
        "og_type",
        "styles",
        "schema_version",
        "content_type",
        "slug",
        "status",
        "order",
        "owner",
        "languages",
        "translation_state",
        "seo",
        "review",
        "project_id",
        "featured",
        "media_state",
        "claims_state",
        "title",
        "summary",
        "card_title",
        "organization",
        "period",
        "category",
        "status_label",
        "built_capability",
        "context",
        "method",
        "evidence",
        "navigation"
      ],
      "properties": {
        "layout": {
          "const": "project"
        },
        "permalink": {
          "type": "string",
          "pattern": "^/projects/[a-z0-9]+(?:-[a-z0-9]+)*\\.html$"
        },
        "body_class": {
          "type": "string",
          "minLength": 1
        },
        "nav_active": {
          "type": "string",
          "enum": [
            "work",
            "knowledge"
          ]
        },
        "robots": {
          "type": "string",
          "minLength": 1
        },
        "og_type": {
          "type": "string",
          "minLength": 1
        },
        "styles": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^/assets/[a-zA-Z0-9/_-]+\\.css$"
          }
        },
        "schema_version": {
          "const": "2.0"
        },
        "content_type": {
          "const": "project"
        },
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "under_review",
            "published",
            "archived"
          ]
        },
        "order": {
          "type": "integer",
          "minimum": 1
        },
        "owner": {
          "const": "Ahmed Hassouna"
        },
        "languages": {
          "type": "array",
          "const": [
            "ar",
            "en"
          ]
        },
        "translation_state": {
          "type": "string",
          "enum": [
            "incomplete",
            "ready_for_review",
            "approved"
          ]
        },
        "created_at": {
          "$ref": "#/$defs/timezoneDateTime"
        },
        "updated_at": {
          "$ref": "#/$defs/timezoneDateTime"
        },
        "claims": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/claim"
          }
        },
        "seo": {
          "$ref": "#/$defs/seo"
        },
        "review": {
          "$ref": "#/$defs/review"
        },
        "project_id": {
          "type": "string",
          "pattern": "^AH-PRJ-[0-9]{3}$"
        },
        "featured": {
          "type": "boolean"
        },
        "media_state": {
          "type": "string",
          "enum": [
            "not_assessed",
            "none",
            "planned",
            "ready"
          ]
        },
        "claims_state": {
          "type": "string",
          "enum": [
            "not_assessed",
            "none",
            "legacy_embedded",
            "structured"
          ]
        },
        "title": {
          "$ref": "#/$defs/localizedText"
        },
        "summary": {
          "$ref": "#/$defs/localizedText"
        },
        "card_title": {
          "type": "string",
          "minLength": 1
        },
        "organization": {
          "type": "string",
          "minLength": 1
        },
        "period": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "$ref": "#/$defs/localizedText"
        },
        "status_label": {
          "$ref": "#/$defs/localizedText"
        },
        "built_capability": {
          "$ref": "#/$defs/localizedText"
        },
        "context": {
          "$ref": "#/$defs/localizedText"
        },
        "method": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "diagnosis",
            "design",
            "stabilization"
          ],
          "properties": {
            "diagnosis": {
              "$ref": "#/$defs/localizedText"
            },
            "design": {
              "$ref": "#/$defs/localizedText"
            },
            "stabilization": {
              "$ref": "#/$defs/localizedText"
            }
          }
        },
        "evidence": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "evidence_basis",
            "documented_impact",
            "claim_boundaries",
            "transferable_value"
          ],
          "properties": {
            "evidence_basis": {
              "$ref": "#/$defs/localizedText"
            },
            "documented_impact": {
              "$ref": "#/$defs/localizedText"
            },
            "claim_boundaries": {
              "$ref": "#/$defs/localizedText"
            },
            "transferable_value": {
              "$ref": "#/$defs/localizedText"
            }
          }
        },
        "media": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "src",
            "decorative"
          ],
          "properties": {
            "src": {
              "type": "string",
              "pattern": "^/assets/[a-zA-Z0-9/_-]+\\.(?:webp|jpg|jpeg|png|svg)$"
            },
            "decorative": {
              "type": "boolean"
            },
            "alt": {
              "$ref": "#/$defs/localizedText"
            },
            "thumbnail": {
              "$ref": "#/$defs/mediaAsset"
            },
            "cover": {
              "$ref": "#/$defs/mediaAsset"
            },
            "gallery": {
              "type": "array",
              "minItems": 1,
              "maxItems": 12,
              "items": {
                "$ref": "#/$defs/mediaAsset"
              }
            }
          },
          "allOf": [
            {
              "if": {
                "properties": {
                  "decorative": {
                    "const": false
                  }
                },
                "required": [
                  "decorative"
                ]
              },
              "then": {
                "required": [
                  "alt"
                ]
              }
            },
            {
              "if": {
                "properties": {
                  "decorative": {
                    "const": true
                  }
                },
                "required": [
                  "decorative"
                ]
              },
              "then": {
                "not": {
                  "required": [
                    "alt"
                  ]
                }
              }
            }
          ]
        },
        "navigation": {
          "$ref": "#/$defs/navigation"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "media_state": {
                "const": "ready"
              }
            },
            "required": [
              "media_state"
            ]
          },
          "then": {
            "required": [
              "media"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "media_state": {
                "enum": [
                  "not_assessed",
                  "none",
                  "planned"
                ]
              }
            },
            "required": [
              "media_state"
            ]
          },
          "then": {
            "not": {
              "required": [
                "media"
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "claims_state": {
                "const": "structured"
              }
            },
            "required": [
              "claims_state"
            ]
          },
          "then": {
            "required": [
              "claims"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "claims_state": {
                "enum": [
                  "not_assessed",
                  "none",
                  "legacy_embedded"
                ]
              }
            },
            "required": [
              "claims_state"
            ]
          },
          "then": {
            "not": {
              "required": [
                "claims"
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "claims_state": {
                "const": "legacy_embedded"
              }
            },
            "required": [
              "claims_state"
            ]
          },
          "then": {
            "properties": {
              "project_id": {
                "enum": [
                  "AH-PRJ-001",
                  "AH-PRJ-002",
                  "AH-PRJ-003",
                  "AH-PRJ-004",
                  "AH-PRJ-005"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "published"
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "properties": {
              "translation_state": {
                "const": "approved"
              },
              "media_state": {
                "const": "ready"
              },
              "claims_state": {
                "not": {
                  "const": "not_assessed"
                }
              },
              "review": {
                "allOf": [
                  {
                    "properties": {
                      "content_review_state": {
                        "const": "approved"
                      }
                    }
                  },
                  {
                    "properties": {
                      "claim_review_state": {
                        "const": "approved"
                      }
                    }
                  }
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "review": {
                "properties": {
                  "timestamp_state": {
                    "const": "legacy_unrecorded"
                  }
                },
                "required": [
                  "timestamp_state"
                ]
              }
            },
            "required": [
              "review"
            ]
          },
          "then": {
            "properties": {
              "project_id": {
                "enum": [
                  "AH-PRJ-001",
                  "AH-PRJ-002",
                  "AH-PRJ-003",
                  "AH-PRJ-004",
                  "AH-PRJ-005"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "claims": {
                "contains": {
                  "type": "object",
                  "properties": {
                    "approval_state": {
                      "const": "baseline_approved"
                    }
                  },
                  "required": [
                    "approval_state"
                  ]
                }
              }
            },
            "required": [
              "claims"
            ]
          },
          "then": {
            "properties": {
              "project_id": {
                "enum": [
                  "AH-PRJ-001",
                  "AH-PRJ-002",
                  "AH-PRJ-003",
                  "AH-PRJ-004",
                  "AH-PRJ-005"
                ]
              }
            }
          }
        }
      ]
    },
    "article": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "layout",
        "permalink",
        "body_class",
        "nav_active",
        "robots",
        "og_type",
        "styles",
