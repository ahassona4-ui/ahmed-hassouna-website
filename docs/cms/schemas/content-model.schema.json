        },
        "article_id": {
          "type": "string",
          "pattern": "^AH-ART-[0-9]{3}$"
        },
        "publication_date_state": {
          "type": "string",
          "enum": [
            "unassigned",
            "legacy_pending",
            "recorded"
          ]
        },
        "published_at": {
          "type": "string",
          "format": "date"
        },
        "media_state": {
          "type": "string",
          "enum": [
            "not_assessed",
            "none",
            "planned",
            "ready"
          ]
        },
        "claims_state": {
          "type": "string",
          "enum": [
            "not_assessed",
            "none",
            "structured"
          ]
        },
        "author": {
          "const": "Ahmed Hassouna"
        },
        "category": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "$ref": "#/$defs/localizedText"
        },
        "summary": {
          "$ref": "#/$defs/localizedText"
        },
        "lead": {
          "$ref": "#/$defs/localizedText"
        },
        "sections": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/articleSection"
          }
        },
        "quote": {
          "$ref": "#/$defs/localizedText"
        },
        "media": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "cover": {
              "$ref": "#/$defs/mediaAsset"
            },
            "gallery": {
              "type": "array",
              "minItems": 1,
              "maxItems": 12,
              "items": {
                "$ref": "#/$defs/mediaAsset"
              }
            }
          },
          "anyOf": [
            {
              "required": [
                "cover"
              ]
            },
            {
              "required": [
                "gallery"
              ]
            }
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "publication_date_state": {
                "const": "recorded"
              }
            },
            "required": [
              "publication_date_state"
            ]
          },
          "then": {
            "required": [
              "published_at"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "publication_date_state": {
                "enum": [
                  "unassigned",
                  "legacy_pending"
                ]
              }
            },
            "required": [
              "publication_date_state"
            ]
          },
          "then": {
            "not": {
              "required": [
                "published_at"
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "publication_date_state": {
                "const": "unassigned"
              }
            },
            "required": [
              "publication_date_state"
            ]
          },
          "then": {
            "properties": {
              "status": {
                "enum": [
                  "draft",
                  "under_review"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "publication_date_state": {
                "const": "legacy_pending"
              }
            },
            "required": [
              "publication_date_state"
            ]
          },
          "then": {
            "properties": {
              "article_id": {
                "enum": [
                  "AH-ART-001",
                  "AH-ART-002",
                  "AH-ART-003"
                ]
              },
              "status": {
                "const": "published"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "media_state": {
                "const": "ready"
              }
            },
            "required": [
              "media_state"
            ]
          },
          "then": {
            "required": [
              "media"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "media_state": {
                "enum": [
                  "not_assessed",
                  "none",
                  "planned"
                ]
              }
            },
            "required": [
              "media_state"
            ]
          },
          "then": {
            "not": {
              "required": [
                "media"
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "claims_state": {
                "const": "structured"
              }
            },
            "required": [
              "claims_state"
            ]
          },
          "then": {
            "required": [
              "claims"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "claims_state": {
                "enum": [
                  "not_assessed",
                  "none"
                ]
              }
            },
            "required": [
              "claims_state"
            ]
          },
          "then": {
            "not": {
              "required": [
                "claims"
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "published"
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "properties": {
              "publication_date_state": {
                "not": {
                  "const": "unassigned"
                }
              },
              "translation_state": {
                "const": "approved"
              },
              "media_state": {
                "enum": [
                  "none",
                  "ready"
                ]
              },
              "claims_state": {
                "not": {
                  "const": "not_assessed"
                }
              },
              "review": {
                "allOf": [
                  {
                    "properties": {
                      "content_review_state": {
                        "const": "approved"
                      }
                    }
                  },
                  {
                    "properties": {
                      "claim_review_state": {
                        "const": "approved"
                      }
                    }
                  }
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "review": {
                "properties": {
                  "timestamp_state": {
                    "const": "legacy_unrecorded"
                  }
                },
                "required": [
                  "timestamp_state"
                ]
              }
            },
            "required": [
              "review"
            ]
          },
          "then": {
            "properties": {
              "article_id": {
                "enum": [
                  "AH-ART-001",
                  "AH-ART-002",
                  "AH-ART-003"
                ]
              }
            }
          }
        },
        {
          "not": {
            "properties": {
              "claims": {
                "contains": {
                  "type": "object",
                  "properties": {
                    "approval_state": {
                      "const": "baseline_approved"
                    }
                  },
                  "required": [
                    "approval_state"
                  ]
                }
              }
            },
            "required": [
              "claims"
            ]
          }
        }
      ]
    },
    "timezoneDateTime": {
      "type": "string",
      "format": "date-time",
      "pattern": "(?:Z|[+-][0-9]{2}:[0-9]{2})$"
    }
  }
}
